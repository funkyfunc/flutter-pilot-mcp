{
  "name": "flutter-pilot-mcp",
  "version": "1.0.0",
  "description": "An MCP server that lets AI agents drive Flutter apps — tap, type, scroll, assert, and screenshot live UIs via integration_test.",
  "author": "funkyfunc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/funkyfunc/flutter-pilot-mcp.git"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc && cp src/harness.dart dist/src/ && npm run verify-harness",
    "start": "node dist/src/index.js",
    "watch": "tsc --watch",
    "verify-harness": "node dist/verification/verify_harness_syntax.js",
    "verify": "node dist/verification/verify.js",
    "verify-integration": "node dist/verification/verify_integration.js",
    "verify-validate": "node dist/verification/verify_validate.js",
    "verify-tools": "node dist/verification/verify_tools.js",
    "verify-scroll": "node dist/verification/verify_scroll.js",
    "verify-screenshot": "node dist/verification/verify_screenshot.js"
  },
  "keywords": ["mcp", "flutter", "testing", "ai", "llm", "integration-test", "model-context-protocol"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "execa": "^9.6.1",
    "ws": "^8.18.3",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
